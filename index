<style>
  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --border: #1e1e2e;
    --accent: #c8a96e;
    --accent2: #4a9eff;
    --text: #e8e8f0;
    --muted: #6b6b8a;
    --green: #3ddc84;
    --yellow: #f5c842;
    --red: #ff5252;
    --red-dark: #c62828;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(200,169,110,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(200,169,110,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px 24px;
    position: relative;
    z-index: 1;
  }

  header {
    margin-bottom: 48px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 32px;
    text-align: center;
  }

  .label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
    display: block;
  }

  .label a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(200,169,110,0.4);
    transition: border-color 0.2s, color 0.2s;
  }

  .label a:hover {
    color: #e8c98e;
    border-bottom-color: #e8c98e;
  }

  h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 10vw, 96px);
    letter-spacing: 8px;
    line-height: 1;
    color: var(--text);
    margin-bottom: 16px;
    white-space: nowrap;
  }

  h1 span {
    color: var(--accent);
  }

  .subtitle {
    font-size: 14px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
    max-width: 600px;
    line-height: 1.6;
    margin: 0 auto;
  }

  /* Search */
  .search-section {
    margin-bottom: 40px;
    position: relative;
  }

  .search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .search-icon {
    position: absolute;
    left: 20px;
    font-size: 16px;
    color: var(--muted);
    pointer-events: none;
  }

  #searchInput {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px 20px 16px 50px;
    font-family: 'DM Mono', monospace;
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    letter-spacing: 1px;
  }

  #searchInput:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(200,169,110,0.1);
  }

  #searchInput::placeholder { color: var(--muted); }

  /* Suggestions */
  .suggestions {
    position: absolute;
    top: calc(100% + 4px);
    left: 0; right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    z-index: 100;
    overflow: hidden;
    display: none;
  }

  .suggestions.show { display: block; }

  .suggestion-item {
    padding: 12px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    transition: background 0.15s;
    border-bottom: 1px solid var(--border);
  }

  .suggestion-item:last-child { border-bottom: none; }
  .suggestion-item:hover, .suggestion-item.active { background: var(--border); }

  .suggestion-flag { font-size: 20px; }
  .suggestion-name { color: var(--text); }
  .suggestion-score { margin-left: auto; color: var(--accent); font-size: 12px; }

  /* Counter */
  .results-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }

  .results-count {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  .results-count span { color: var(--accent); }

  .reset-btn {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    background: none;
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 3px;
    cursor: pointer;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.2s;
  }

  .reset-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Table */
  .table-container {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  thead tr {
    background: #0d0d16;
    border-bottom: 1px solid var(--accent);
  }

  thead th {
    padding: 14px 16px;
    text-align: left;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  thead th.country-col {
    color: var(--accent);
    min-width: 140px;
  }

  thead th.indicator-col {
    min-width: 190px;
    position: sticky;
    left: 0;
    background: #0d0d16;
    z-index: 2;
  }

  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(200,169,110,0.03); }

  tbody tr.total-row {
    background: #0d0d16;
    border-top: 1px solid var(--accent);
  }

  tbody tr.total-row td {
    font-family: 'DM Mono', monospace;
    font-weight: 500;
    color: var(--accent);
  }

  td {
    padding: 10px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    white-space: nowrap;
  }

  td.indicator-name {
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.5px;
    position: sticky;
    left: 0;
    background: var(--surface);
    z-index: 1;
  }

  tbody tr:hover td.indicator-name { background: #161621; }
  tbody tr.total-row td.indicator-name { background: #0d0d16; color: var(--accent); font-size: 11px; }

  .score-cell {
    text-align: center;
    font-size: 13px;
    font-weight: 500;
  }

  .score-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 24px;
    border-radius: 3px;
    font-size: 12px;
    font-weight: 500;
  }

  /* Country header in table */
  .country-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .country-flag-header { font-size: 22px; line-height: 1; }
  .country-name-header { font-size: 9px; letter-spacing: 1.5px; color: var(--text); }
  .country-total-header { font-size: 10px; color: var(--accent); }

  /* Rank badge */
  .rank-badge {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    padding: 1px 6px;
    border-radius: 2px;
    letter-spacing: 1px;
    margin-top: 2px;
  }

  /* Empty state */
  .empty-state {
    text-align: center;
    padding: 80px 24px;
    display: none;
  }

  .empty-state.show { display: block; }
  .empty-icon { font-size: 48px; margin-bottom: 16px; }
  .empty-text { font-family: 'DM Mono', monospace; color: var(--muted); font-size: 13px; }

  /* Sources */
  .sources {
    margin-top: 32px;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
  }

  .sources p {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    line-height: 1.8;
    letter-spacing: 0.5px;
  }

  .sources p strong { color: var(--accent); }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  tbody tr {
    animation: fadeIn 0.25s ease forwards;
  }

  thead th:first-child { border-radius: 6px 0 0 0; }
</style>
</head>
