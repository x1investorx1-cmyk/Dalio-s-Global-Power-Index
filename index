// Remove duplicate Poland entry
const seen = new Set();
const COUNTRIES_CLEAN = COUNTRIES.filter(c => {
  const key = c.name + c.flag;
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

// Compute totals and global rank
COUNTRIES_CLEAN.forEach(c => {
  c.total = c.scores.reduce((a, b) => a + b, 0);
});
COUNTRIES_CLEAN.sort((a, b) => b.total - a.total);
COUNTRIES_CLEAN.forEach((c, i) => { c.rank = i + 1; });

const TOTAL_COUNTRIES = COUNTRIES_CLEAN.length;
let displayed = COUNTRIES_CLEAN.slice(0, 5);

document.getElementById('totalLabel').textContent = TOTAL_COUNTRIES;

function scoreColor(v) {
  if (v >= 9) return { bg: '#1b5e20', text: '#a5d6a7' };
  if (v >= 7) return { bg: '#2e7d32', text: '#c8e6c9' };
  if (v >= 5) return { bg: '#1a3a1a', text: '#81c784' };
  if (v === 4) return { bg: '#3a2e00', text: '#fff176' };
  if (v === 3) return { bg: '#4a1a00', text: '#ffcc80' };
  if (v === 2) return { bg: '#5c1010', text: '#ef9a9a' };
  return { bg: '#7c0000', text: '#ff8a80' };
}

function renderTable(countries) {
  const head = document.getElementById('tableHead');
  const body = document.getElementById('tableBody');

  // Header
  let hRow = `<tr><th class="indicator-col">INDICATOR</th>`;
  countries.forEach(c => {
    hRow += `<th class="country-col">
      <div class="country-header">
        <span class="country-flag-header">${c.flag}</span>
        <span class="country-name-header">${c.name.toUpperCase()}</span>
        <span class="country-total-header">${c.total}/170</span>
        <span class="rank-badge">#${c.rank}</span>
      </div>
    </th>`;
  });
  hRow += '</tr>';
  head.innerHTML = hRow;

  // Body
  let rows = '';
  INDICATORS.forEach((ind, i) => {
    rows += `<tr><td class="indicator-name">${ind}</td>`;
    countries.forEach(c => {
      const v = c.scores[i];
      const col = scoreColor(v);
      rows += `<td class="score-cell">
        <span class="score-pill" style="background:${col.bg};color:${col.text}">${v}</span>
      </td>`;
    });
    rows += '</tr>';
  });

  // Total row
  rows += `<tr class="total-row"><td class="indicator-name">TOTAL / 170</td>`;
  countries.forEach(c => {
    rows += `<td class="score-cell" style="color:var(--accent);font-weight:600;font-size:14px">${c.total}</td>`;
  });
  rows += '</tr>';

  body.innerHTML = rows;
  document.getElementById('countLabel').textContent = countries.length;
}

renderTable(displayed);

// ─── SEARCH ──────────────────────────────────────────────────────────────────
const input = document.getElementById('searchInput');
const suggestionsEl = document.getElementById('suggestions');
const emptyState = document.getElementById('emptyState');
const tableContainer = document.getElementById('tableContainer');
let selectedIndex = -1;
let currentSuggestions = [];

function showSuggestions(query) {
  if (!query.trim()) {
    suggestionsEl.classList.remove('show');
    return;
  }
  const q = query.toLowerCase();
  currentSuggestions = COUNTRIES_CLEAN.filter(c =>
    c.name.toLowerCase().includes(q)
  ).slice(0, 8);

  if (currentSuggestions.length === 0) {
    suggestionsEl.classList.remove('show');
    return;
  }

  suggestionsEl.innerHTML = currentSuggestions.map((c, i) => `
    <div class="suggestion-item" data-index="${i}">
      <span class="suggestion-flag">${c.flag}</span>
      <span class="suggestion-name">${c.name}</span>
      <span class="suggestion-score">RANK #${c.rank} · ${c.total}/170</span>
    </div>
  `).join('');

  suggestionsEl.classList.add('show');
  selectedIndex = -1;

  suggestionsEl.querySelectorAll('.suggestion-item').forEach(el => {
    el.addEventListener('click', () => {
      selectCountry(currentSuggestions[+el.dataset.index]);
    });
  });
}

function selectCountry(country) {
  // If already showing this country, skip
  if (displayed.find(c => c.name === country.name)) {
    input.value = '';
    suggestionsEl.classList.remove('show');
    return;
  }

  // Replace top 5: shift out oldest, add new
  if (displayed.length >= 5) displayed.shift();
  displayed.push(country);

  tableContainer.style.display = 'block';
  emptyState.classList.remove('show');
  renderTable(displayed);
  input.value = '';
  suggestionsEl.classList.remove('show');
}

input.addEventListener('input', e => showSuggestions(e.target.value));

input.addEventListener('keydown', e => {
  const items = suggestionsEl.querySelectorAll('.suggestion-item');
  if (e.key === 'ArrowDown') {
    selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
  } else if (e.key === 'ArrowUp') {
    selectedIndex = Math.max(selectedIndex - 1, 0);
  } else if (e.key === 'Enter' && selectedIndex >= 0) {
    selectCountry(currentSuggestions[selectedIndex]);
    return;
  } else if (e.key === 'Escape') {
    suggestionsEl.classList.remove('show');
    return;
  }
  items.forEach((el, i) => el.classList.toggle('active', i === selectedIndex));
});

document.addEventListener('click', e => {
  if (!e.target.closest('.search-section')) {
    suggestionsEl.classList.remove('show');
  }
});

document.getElementById('resetBtn').addEventListener('click', () => {
  displayed = COUNTRIES_CLEAN.slice(0, 5);
  input.value = '';
  suggestionsEl.classList.remove('show');
  tableContainer.style.display = 'block';
  emptyState.classList.remove('show');
  renderTable(displayed);
});
</script>
